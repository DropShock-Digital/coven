{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Coven",
  "description": "A framework for building intelligent agents with persistent memory, multi-agent delegation, and seamless integration across platforms. Run agents autonomously with Coven's harness system.",
  "theme": "mint",
  "icons": {
    "library": "lucide"
  },
  "logo": {
    "light": "/assets/coven-logo.svg",
    "dark": "/assets/coven-logo-dark.svg"
  },
  "fonts": {
    "body": {
      "family": "Fragment Mono"
    },
    "heading": {
      "family": "DM Sans"
    }
  },
  "favicon": "/assets/coven-favicon.svg",
  "colors": {
    "primary": "#7C3AED",
    "dark": "#7C3AED",
    "light": "#A78BFA"
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "dark": "min-dark",
        "light": "min-light"
      }
    }
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/opencoven/coven",
        "icon": "github"
      },
      {
        "label": "Discord",
        "href": "https://discord.com/invite/coven",
        "icon": "discord"
      }
    ]
  },
